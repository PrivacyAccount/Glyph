{
  "appId": "com.glyph.client",
  "productName": "Glyph Client",
  "directories": {
    "output": "dist-client"
  },
  "files": [
    "dist/**/*",
    "electron/main.js",
    "electron/preload.js",
    "electron/splash.html",
    "electron/mpvController.js",
    "src/assets/icons/glyph.ico",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "vendor",
      "to": "vendor",
      "filter": [
        "**/*"
      ]
    }
  ],
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "afterPack": "electron/afterPack.js",
  "mac": {
    "icon": "src/assets/icons/glyph-linux.png",
    "target": [
      "dmg",
      "zip"
    ],
    "category": "public.app-category.video"
  },
  "win": {
    "signAndEditExecutable": false,
    "icon": "src/assets/icons/glyph.ico",
    "target": [
      "nsis"
    ]
  },
  "linux": {
    "icon": "src/assets/icons/glyph-linux.png",
    "target": [
      "AppImage"
    ],
    "category": "AudioVideo"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "license": "EULA.txt",
    "include": "build/uninstall-cleanup.nsh"
  }
}
